# ════════════════════════════════════════════════════════════════
# .env.example — arquitectura.tv
# Copia este archivo como .env.local para desarrollo
# NUNCA subas .env.local al repositorio
# ════════════════════════════════════════════════════════════════

# ─── Site ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://arquitectura.tv

# ─── Sanity CMS ───────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=tu-project-id-aqui
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=tu-sanity-api-token-con-permisos-de-escritura

# ─── Analytics ────────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=arquitectura.tv

# ─── Google Search Console ────────────────────────────────────
NEXT_PUBLIC_GOOGLE_VERIFICATION=tu-codigo-de-verificacion

# ─── Stripe (Membresías) ──────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_PRO_ANNUAL_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_STUDIO_PRICE_ID=price_xxxxxxxxxxxxx
STRIPE_STUDIO_ANNUAL_PRICE_ID=price_xxxxxxxxxxxxx

# ─── Email / Newsletter ───────────────────────────────────────
# Opción A: Mailchimp
MAILCHIMP_API_KEY=xxxxxxxxxxxxx-us1
MAILCHIMP_AUDIENCE_ID=xxxxxxxxxxxxx
MAILCHIMP_SERVER_PREFIX=us1

# Opción B: Resend (más moderno, recomendado)
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_AUDIENCE_ID=xxxxxxxxxxxxx
EMAIL_FROM=hola@arquitectura.tv

# ─── Cloudflare ───────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=tu-account-id
CLOUDFLARE_API_TOKEN=tu-api-token
CLOUDFLARE_ZONE_ID=tu-zone-id

# Cloudflare Stream (videos)
CLOUDFLARE_STREAM_ACCOUNT_ID=tu-account-id
CLOUDFLARE_STREAM_API_TOKEN=tu-stream-token

# Cloudflare R2 (almacenamiento de archivos)
CLOUDFLARE_R2_BUCKET_NAME=arquitectura-tv-assets
CLOUDFLARE_R2_ACCESS_KEY_ID=tu-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=tu-secret-key
CLOUDFLARE_R2_ENDPOINT=https://xxxxx.r2.cloudflarestorage.com

# ─── Database (si usas D1 o Turso) ────────────────────────────
DATABASE_URL=libsql://tu-db.turso.io
DATABASE_AUTH_TOKEN=tu-auth-token

# ─── Auth (NextAuth / Clerk) ──────────────────────────────────
# Opción A: NextAuth.js
NEXTAUTH_URL=https://arquitectura.tv
NEXTAUTH_SECRET=un-secreto-muy-largo-y-aleatorio-aqui

# Opción B: Clerk (más simple, recomendado para v1)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_live_xxxxxxxxxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/cuenta/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/cuenta/registro

# ─── Search (Algolia) ─────────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=XXXXXXXXXX
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=tu-search-only-api-key
ALGOLIA_ADMIN_KEY=tu-admin-key
ALGOLIA_INDEX_NAME=arquitectura-tv

# ─── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=https://xxxxx@o0.ingest.sentry.io/0
SENTRY_AUTH_TOKEN=tu-sentry-auth-token
